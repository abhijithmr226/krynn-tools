{
  "framework": "vite",
  "buildCommand": "pnpm --filter @workspace/krynn-tools run build",
  "outputDirectory": "artifacts/krynn-tools/dist/public",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
