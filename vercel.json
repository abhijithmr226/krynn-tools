{
  "buildCommand": "cd artifacts/krynn-tools && npm run build",
  "outputDirectory": "artifacts/krynn-tools/dist/public",
  "installCommand": "npm install -g pnpm && pnpm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/cron",
      "destination": "/api/cron.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 0 * * *"
    }
  ]
}
