{
  "buildCommand": "cd artifacts/krynn-tools && pnpm run build",
  "outputDirectory": "artifacts/krynn-tools/dist/public",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
